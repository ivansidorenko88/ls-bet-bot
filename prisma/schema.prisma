generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  discordId String   @unique
  username  String
  balance   Int      @default(0)
  createdAt DateTime @default(now())

  // Registration / verification data
  registrationStatus String?
  registeredFullName String?
  registeredPhone    String?
  registeredAge      Int?
  registeredAt       DateTime?

  referredByUserId Int?
  refPercent       Int?

  referredBy User?  @relation("UserReferrals", fields: [referredByUserId], references: [id])
  referrals  User[] @relation("UserReferrals")

  bets             Bet[]
  transactions     Transaction[]
  topUpRequests    TopUpRequest[]
  withdrawRequests WithdrawRequest[]
  lotteryTickets   LotteryTicket[]
  crashBets        CrashBet[]

  registrationRequests RegistrationRequest[]
  jackpotContributions JackpotContribution[]

  coinflipCreated  CoinflipGame[] @relation("CoinflipCreated")
  coinflipOpponent CoinflipGame[] @relation("CoinflipOpponent")
  coinflipWins     CoinflipGame[] @relation("CoinflipWinner")

  promoActivations PromoActivation[]
  ownedPromoCodes  PromoCode[] @relation("PromoOwner")

  referralRewardsReceived ReferralReward[] @relation("ReferralRewardReferrer")
  referralRewardsGiven    ReferralReward[] @relation("ReferralRewardReferred")
}

model RegistrationRequest {
  id              Int       @id @default(autoincrement())
  userId          Int
  fullName        String
  phone           String
  age             Int
  status          String    @default("PENDING")
  ticketChannelId String?
  processedBy     String?
  processedAt     DateTime?
  rejectReason    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model RpEvent {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  status      String   @default("OPEN")
  closesAt    DateTime
  createdBy   String?
  messageId   String?
  channelId   String?
  facebrowserPostId String?
  createdAt   DateTime @default(now())

  options EventOption[]
  bets    Bet[]
}

model EventOption {
  id       Int     @id @default(autoincrement())
  eventId  Int
  title    String
  odds     Float
  imageUrl String?
  isWinner Boolean @default(false)

  event RpEvent @relation(fields: [eventId], references: [id])
  bets  Bet[]
}

model Bet {
  id           Int      @id @default(autoincrement())
  userId       Int
  eventId      Int
  optionId     Int
  amount       Int
  potentialWin Int
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())

  user   User        @relation(fields: [userId], references: [id])
  event  RpEvent     @relation(fields: [eventId], references: [id])
  option EventOption @relation(fields: [optionId], references: [id])
}

model Transaction {
  id        Int      @id @default(autoincrement())
  userId    Int
  amount    Int
  type      String
  comment   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model TopUpRequest {
  id              Int       @id @default(autoincrement())
  userId          Int
  login           String
  amount          Int
  comment         String?
  screenshotUrl   String?
  ticketChannelId String?
  status          String    @default("PENDING")
  processedBy     String?
  processedAt     DateTime?
  createdAt       DateTime  @default(now())

  user            User             @relation(fields: [userId], references: [id])
  referralRewards ReferralReward[]
}

model WithdrawRequest {
  id              Int       @id @default(autoincrement())
  userId          Int
  login           String
  amount          Int
  commission      Int
  payoutAmount    Int
  details         String
  comment         String?
  ticketChannelId String?
  status          String    @default("PENDING")
  processedBy     String?
  processedAt     DateTime?
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])
}

model BotLog {
  id        Int      @id @default(autoincrement())
  type      String
  message   String
  userId    String?
  channelId String?
  createdAt DateTime @default(now())
}

model CoinflipGame {
  id             Int       @id @default(autoincrement())
  creatorUserId  Int
  opponentUserId Int?
  winnerUserId   Int?

  amount       Int
  creatorSide  String
  opponentSide String?
  resultSide   String?

  status    String  @default("WAITING")
  messageId String?
  channelId String?

  createdAt  DateTime  @default(now())
  finishedAt DateTime?

  creator  User  @relation("CoinflipCreated", fields: [creatorUserId], references: [id])
  opponent User? @relation("CoinflipOpponent", fields: [opponentUserId], references: [id])
  winner   User? @relation("CoinflipWinner", fields: [winnerUserId], references: [id])
}

model PromoCode {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  amount      Int
  maxUses     Int?
  usesCount   Int      @default(0)
  isActive    Boolean  @default(true)
  type        String   @default("BONUS")
  ownerUserId Int?
  refPercent  Int?
  createdBy   String?
  createdAt   DateTime @default(now())

  owner       User?             @relation("PromoOwner", fields: [ownerUserId], references: [id])
  activations PromoActivation[]
}

model PromoActivation {
  id          Int      @id @default(autoincrement())
  promoCodeId Int
  userId      Int
  amount      Int
  createdAt   DateTime @default(now())

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([promoCodeId, userId])
}

model ReferralReward {
  id           Int      @id @default(autoincrement())
  referrerId   Int
  referredId   Int
  topUpId      Int?
  amount       Int
  percent      Int
  sourceAmount Int
  createdAt    DateTime @default(now())

  referrer User          @relation("ReferralRewardReferrer", fields: [referrerId], references: [id])
  referred User          @relation("ReferralRewardReferred", fields: [referredId], references: [id])
  topUp    TopUpRequest? @relation(fields: [topUpId], references: [id])
}

model LotteryTicket {
  id            Int      @id @default(autoincrement())
  userId        Int
  numbers       String
  price         Int      @default(1000)
  status        String   @default("ACTIVE")
  prize         Int      @default(0)
  matches       Int      @default(0)
  drawId        Int?
  resultNumbers String?
  createdAt     DateTime @default(now())

  user User         @relation(fields: [userId], references: [id])
  draw LotteryDraw? @relation(fields: [drawId], references: [id])
}

model LotteryDraw {
  id        Int      @id @default(autoincrement())
  numbers   String
  createdAt DateTime @default(now())

  tickets LotteryTicket[]
}

model JackpotWar {
  id          Int      @id @default(autoincrement())
  currentPool Int      @default(0)
  targetPool  Int      @default(500000)
  status      String   @default("ACTIVE")
  winnerId    Int?
  createdAt   DateTime @default(now())
  endedAt     DateTime?

  contributions JackpotContribution[]
}

model JackpotContribution {
  id        Int      @id @default(autoincrement())
  roundId   Int
  userId    Int
  amount    Int
  source    String
  sourceId  String?
  createdAt DateTime @default(now())

  round JackpotWar @relation(fields: [roundId], references: [id])
  user  User       @relation(fields: [userId], references: [id])
}

model CrashRound {
  id         Int      @id @default(autoincrement())
  status     String   @default("BETTING")
  crashPoint Float
  messageId  String?
  channelId  String?
  createdAt  DateTime @default(now())
  startedAt  DateTime?
  endedAt    DateTime?

  bets CrashBet[]
}

model CrashBet {
  id                Int       @id @default(autoincrement())
  roundId           Int
  userId            Int
  amount            Int
  status                String    @default("ACTIVE")
  autoCashoutMultiplier Float?
  cashoutMultiplier     Float?
  payout                Int       @default(0)
  createdAt         DateTime  @default(now())
  cashedOutAt       DateTime?

  round CrashRound @relation(fields: [roundId], references: [id])
  user  User       @relation(fields: [userId], references: [id])
}
