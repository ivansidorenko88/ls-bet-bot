# PostgreSQL connection string from Bothost.
# Keep the real value only in Bothost environment variables.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Source SQLite database used only during the one-time migration.
# The migration script automatically uses prisma/dev.db when this is omitted.
SQLITE_DATABASE_URL="file:./dev.db"

# Safety switch. Leave false for a new, empty PostgreSQL database.
MIGRATION_ALLOW_NONEMPTY=false
